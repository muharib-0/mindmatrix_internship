<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
      Minimal Activity theme — Compose handles all UI theming internally via VirasatTheme.
      This only sets the window background and status bar color.
    -->
    <style name="Theme.VirasatNammaGuide" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="android:statusBarColor">#6B1010</item>
        <item name="android:navigationBarColor">#8B1A1A</item>
        <item name="android:windowBackground">@color/color_background</item>
    </style>
</resources>
